# Application
APP_NAME=File Conversion API
APP_VERSION=1.0.0
DEBUG=false

# API
API_V1_PREFIX=/api/v1

# Server
HOST=0.0.0.0
PORT=8000

# CORS (comma-separated list)
CORS_ORIGINS=*

# File Limits
MAX_FILE_SIZE=52428800  # 50 MB in bytes

# Conversion Settings
IMAGE_QUALITY=85
PDF_DPI=300

# Cleanup
TEMP_FILE_EXPIRY_HOURS=24
